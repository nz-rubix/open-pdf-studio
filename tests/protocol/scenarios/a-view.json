{
  "name": "a-view",
  "description": "Fase A rooktest — Beeld-tab (ViewTab): weergavemodi, paginarotatie, panelen, vergelijken, fullscreen en sneltoets-overlay. Twee blanco documenten (voor Vergelijken); niets wordt opgeslagen.",
  "skippedButtons": [],
  "steps": [
    { "action": "tool", "name": "app_new_blank_pdf", "args": { "widthPt": 595, "heightPt": 842, "pages": 3 }, "store": "newdoc1" },
    { "action": "wait", "ms": 600 },
    { "action": "tool", "name": "app_new_blank_pdf", "args": { "widthPt": 595, "heightPt": 842, "pages": 1 }, "store": "newdoc2" },
    { "action": "wait", "ms": 600 },
    { "action": "tool", "name": "app_list_tabs", "store": "tabs0" },
    { "action": "tool", "name": "app_switch_tab", "args": { "index": "={tabs0.tabs.length - 2}" } },
    { "action": "wait", "ms": 600 },
    { "action": "uiState", "id": "tab-view", "store": "uiTabView" },

    { "action": "clickButton", "id": "continuous" },
    { "action": "wait", "ms": 700 },
    { "action": "probe", "store": "pCont" },
    { "action": "clickButton", "id": "book-view" },
    { "action": "wait", "ms": 700 },
    { "action": "probe", "store": "pBook" },
    { "action": "uiState", "id": "book-view", "store": "uiBook" },
    { "action": "clickButton", "id": "facing-view" },
    { "action": "wait", "ms": 700 },
    { "action": "probe", "store": "pFacing" },
    { "action": "uiState", "id": "facing-view", "store": "uiFacing" },
    { "action": "clickButton", "id": "single-page" },
    { "action": "wait", "ms": 700 },
    { "action": "probe", "store": "pSingle" },

    { "action": "probe", "store": "r0" },
    { "action": "clickButton", "id": "view-rotate-left" },
    { "action": "wait", "ms": 800 },
    { "action": "probe", "store": "r1" },
    { "action": "clickButton", "id": "view-rotate-right" },
    { "action": "wait", "ms": 800 },
    { "action": "probe", "store": "r2" },

    { "action": "uiState", "id": "thin-lines-toggle", "store": "t0" },
    { "action": "clickButton", "id": "thin-lines-toggle" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "thin-lines-toggle", "store": "t1" },
    { "action": "clickButton", "id": "thin-lines-toggle" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "thin-lines-toggle", "store": "t2" },

    { "action": "uiState", "id": "ribbon-nav-panel", "store": "n0" },
    { "action": "clickButton", "id": "ribbon-nav-panel" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-nav-panel", "store": "n1" },
    { "action": "clickButton", "id": "ribbon-nav-panel" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-nav-panel", "store": "n2" },

    { "action": "uiState", "id": "ribbon-properties-panel", "store": "pp0" },
    { "action": "clickButton", "id": "ribbon-properties-panel" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-properties-panel", "store": "pp1" },
    { "action": "clickButton", "id": "ribbon-properties-panel" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-properties-panel", "store": "pp2" },

    { "action": "clickButton", "id": "ribbon-annotations-list" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "selector": "#left-panel:not(.collapsed)", "searchTabs": false, "store": "uiLeftPanelOpen" },

    { "action": "clickButton", "id": "ribbon-element-visibility" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-element-visibility", "store": "ev1" },
    { "action": "uiState", "selector": "#element-visibility-panel", "searchTabs": false, "store": "uiEvPanel" },
    { "action": "clickButton", "id": "ribbon-element-visibility" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-element-visibility", "store": "ev2" },

    { "action": "uiState", "id": "ribbon-symbol-palette", "store": "sp0" },
    { "action": "clickButton", "id": "ribbon-symbol-palette" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-symbol-palette", "store": "sp1" },
    { "action": "clickButton", "id": "ribbon-symbol-palette" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-symbol-palette", "store": "sp2" },

    { "action": "uiState", "id": "ribbon-compare", "store": "cmp0" },
    { "action": "clickButton", "id": "ribbon-compare" },
    { "action": "wait", "ms": 500 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgCompare" },
    { "action": "escape", "ms": 400 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgCompareClosed" },

    { "action": "uiState", "id": "ribbon-fullscreen", "store": "fs0" },
    { "action": "clickButton", "id": "ribbon-fullscreen" },
    { "action": "wait", "ms": 1500 },
    { "action": "uiState", "id": "ribbon-fullscreen", "store": "fs1" },
    { "action": "clickButton", "id": "ribbon-fullscreen" },
    { "action": "wait", "ms": 1500 },
    { "action": "uiState", "id": "ribbon-fullscreen", "store": "fs2" },

    { "action": "clickButton", "id": "ribbon-keystroke-overlay" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-keystroke-overlay", "store": "ko1" },
    { "action": "clickButton", "id": "ribbon-keystroke-overlay" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "ribbon-keystroke-overlay", "store": "ko2" },

    { "action": "tool", "name": "app_list_tabs", "store": "tabsEnd1" },
    { "action": "tool", "name": "app_close_tab", "args": { "index": "={tabsEnd1.tabs.length - 1}", "force": true } },
    { "action": "tool", "name": "app_list_tabs", "store": "tabsEnd2" },
    { "action": "tool", "name": "app_close_tab", "args": { "index": "={tabsEnd2.tabs.length - 1}", "force": true } }
  ],
  "assertions": [
    { "type": "elementFound", "probe": "uiTabView", "label": "tab-view content aanwezig" },
    { "type": "stateEquals", "probe": "pCont", "field": "doc.viewMode", "value": "continuous", "label": "continuous zet doorlopende weergave" },
    { "type": "stateEquals", "probe": "pBook", "field": "doc.viewMode", "value": "continuous", "label": "book-view blijft doorlopend" },
    { "type": "stateEquals", "probe": "pBook", "field": "doc.bookSpread", "value": true, "label": "book-view zet boek-spread" },
    { "type": "elementActive", "probe": "uiBook", "label": "book-view knop actief in boekmodus" },
    { "type": "stateEquals", "probe": "pFacing", "field": "doc.viewMode", "value": "continuous", "label": "facing-view blijft doorlopend" },
    { "type": "elementActive", "probe": "uiFacing", "label": "facing-view knop actief in naast-elkaar-modus" },
    { "type": "stateEquals", "probe": "pSingle", "field": "doc.viewMode", "value": "single", "label": "single-page zet enkelpagina-weergave" },
    { "type": "stateChanged", "preProbe": "r0", "postProbe": "r1", "field": "doc.scale", "label": "view-rotate-left draait pagina (fit-schaal wisselt)" },
    { "type": "stateEqualField", "preProbe": "r0", "postProbe": "r2", "field": "doc.scale", "tolerance": 0.001, "label": "view-rotate-right draait terug" },
    { "type": "stateChanged", "preProbe": "t0", "postProbe": "t1", "field": "active", "label": "thin-lines-toggle wisselt actief-status" },
    { "type": "stateEqualField", "preProbe": "t0", "postProbe": "t2", "field": "active", "label": "thin-lines-toggle terug naar beginstand" },
    { "type": "stateChanged", "preProbe": "n0", "postProbe": "n1", "field": "active", "label": "ribbon-nav-panel wisselt paneel" },
    { "type": "stateEqualField", "preProbe": "n0", "postProbe": "n2", "field": "active", "label": "ribbon-nav-panel terug naar beginstand" },
    { "type": "stateChanged", "preProbe": "pp0", "postProbe": "pp1", "field": "active", "label": "ribbon-properties-panel wisselt paneel" },
    { "type": "stateEqualField", "preProbe": "pp0", "postProbe": "pp2", "field": "active", "label": "ribbon-properties-panel terug naar beginstand" },
    { "type": "elementFound", "probe": "uiLeftPanelOpen", "label": "ribbon-annotations-list klapt linkerpaneel open" },
    { "type": "elementActive", "probe": "ev1", "label": "ribbon-element-visibility actief na klik" },
    { "type": "elementFound", "probe": "uiEvPanel", "label": "element-zichtbaarheid-paneel zichtbaar" },
    { "type": "elementActive", "probe": "ev2", "active": false, "label": "ribbon-element-visibility uit na tweede klik" },
    { "type": "stateChanged", "preProbe": "sp0", "postProbe": "sp1", "field": "active", "label": "ribbon-symbol-palette wisselt palette" },
    { "type": "stateEqualField", "preProbe": "sp0", "postProbe": "sp2", "field": "active", "label": "ribbon-symbol-palette terug naar beginstand" },
    { "type": "elementEnabled", "probe": "cmp0", "label": "ribbon-compare enabled met 2 documenten" },
    { "type": "dialogOpen", "probe": "dlgCompare", "label": "ribbon-compare opent vergelijken-dialoog" },
    { "type": "dialogOpen", "probe": "dlgCompareClosed", "open": false, "label": "Escape sluit vergelijken-dialoog" },
    { "type": "elementEnabled", "probe": "fs0", "label": "ribbon-fullscreen aanwezig en enabled (state-toggle: bekende afwijking, zie eindrapport)" },
    { "type": "elementActive", "probe": "ko1", "label": "ribbon-keystroke-overlay actief na klik" },
    { "type": "elementActive", "probe": "ko2", "active": false, "label": "ribbon-keystroke-overlay uit na tweede klik" }
  ]
}
