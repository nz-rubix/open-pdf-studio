{
  "name": "03-tools-draw-shortcuts",
  "description": "Each keyboard-shortcut drawing tool (box, circle, draw/freehand, line, textbox, comment) must (a) activate via its hotkey and (b) produce an annotation when used. Verifies the chord-eats-T fix and the pointer-event dual-dispatch fix. Click/drag coordinates are probe-relative so the test works regardless of side-panel state.",
  "setup": {
    "pdfPath": "test pdf-bestanden/Originele bestanden/Text pdf gecombineerd.pdf",
    "scale": 1.0,
    "page": 2
  },
  "steps": [
    { "action": "key", "key": "v" },
    { "action": "wait", "ms": 300 },
    { "action": "probe", "store": "init" },
    { "action": "probe", "store": "start" },

    { "action": "key", "key": "4" },
    { "action": "wait", "ms": 300 },
    { "action": "mouse_drag",
      "x1": "={init.container.left + init.container.width/2 - 60}",
      "y1": "={init.container.top + 250}",
      "x2": "={init.container.left + init.container.width/2 + 60}",
      "y2": "={init.container.top + 380}",
      "steps": 15 },
    { "action": "wait", "ms": 500 },
    { "action": "key", "key": "Escape" },
    { "action": "wait", "ms": 200 },
    { "action": "probe", "store": "afterBox" },

    { "action": "key", "key": "5" },
    { "action": "wait", "ms": 300 },
    { "action": "mouse_drag",
      "x1": "={init.container.left + init.container.width/2 - 50}",
      "y1": "={init.container.top + 410}",
      "x2": "={init.container.left + init.container.width/2 + 50}",
      "y2": "={init.container.top + 510}",
      "steps": 15 },
    { "action": "wait", "ms": 500 },
    { "action": "key", "key": "Escape" },
    { "action": "wait", "ms": 200 },
    { "action": "probe", "store": "afterCircle" },

    { "action": "key", "key": "2" },
    { "action": "wait", "ms": 300 },
    { "action": "mouse_drag",
      "x1": "={init.container.left + init.container.width/2 - 80}",
      "y1": "={init.container.top + 540}",
      "x2": "={init.container.left + init.container.width/2 + 80}",
      "y2": "={init.container.top + 640}",
      "steps": 15 },
    { "action": "wait", "ms": 500 },
    { "action": "key", "key": "Escape" },
    { "action": "wait", "ms": 200 },
    { "action": "probe", "store": "afterDraw" },

    { "action": "key", "key": "3" },
    { "action": "wait", "ms": 300 },
    { "action": "mouse_click",
      "x": "={init.container.left + init.container.width/2 - 100}",
      "y": "={init.container.top + 200}" },
    { "action": "wait", "ms": 250 },
    { "action": "mouse_click",
      "x": "={init.container.left + init.container.width/2 + 100}",
      "y": "={init.container.top + 300}" },
    { "action": "wait", "ms": 500 },
    { "action": "key", "key": "Escape" },
    { "action": "wait", "ms": 200 },
    { "action": "probe", "store": "afterLine" },

    { "action": "key", "key": "t" },
    { "action": "wait", "ms": 300 },
    { "action": "probe", "store": "tToolActive" },
    { "action": "mouse_drag",
      "x1": "={init.container.left + init.container.width/2 - 100}",
      "y1": "={init.container.top + 100}",
      "x2": "={init.container.left + init.container.width/2 + 100}",
      "y2": "={init.container.top + 170}",
      "steps": 10 },
    { "action": "wait", "ms": 500 },
    { "action": "key", "key": "Escape" },
    { "action": "wait", "ms": 200 },
    { "action": "probe", "store": "afterTextbox" },

    { "action": "key", "key": "n" },
    { "action": "wait", "ms": 300 },
    { "action": "mouse_click",
      "x": "={init.container.left + init.container.width/2}",
      "y": "={init.container.top + 60}" },
    { "action": "wait", "ms": 500 },
    { "action": "key", "key": "Escape" },
    { "action": "wait", "ms": 200 },
    { "action": "probe", "store": "afterComment" },

    { "action": "key", "key": "v" },
    { "action": "wait", "ms": 200 },
    { "action": "screenshot", "label": "final" }
  ],
  "assertions": [
    { "type": "stateEquals", "probe": "tToolActive", "field": "currentTool", "value": "textbox", "label": "T hotkey activates textbox (chord-buffer-eats-T fix)" },
    { "type": "annotationCountDelta", "preProbe": "start", "postProbe": "afterBox", "delta": 1, "label": "box drag creates 1 annotation" },
    { "type": "annotationCountDelta", "preProbe": "afterBox", "postProbe": "afterCircle", "delta": 1, "label": "circle drag creates 1 annotation" },
    { "type": "annotationCountDelta", "preProbe": "afterCircle", "postProbe": "afterDraw", "delta": 1, "label": "freehand drag creates 1 annotation" },
    { "type": "annotationCountDelta", "preProbe": "afterDraw", "postProbe": "afterLine", "delta": 1, "label": "line click-click creates 1 annotation" },
    { "type": "annotationCountDelta", "preProbe": "afterLine", "postProbe": "afterTextbox", "delta": 1, "label": "textbox drag creates 1 annotation" },
    { "type": "annotationCountDelta", "preProbe": "afterTextbox", "postProbe": "afterComment", "delta": 1, "label": "comment click creates 1 annotation" }
  ]
}
