{
  "name": "a-comment",
  "description": "Fase A rooktest — Annotatie-tab (CommentTab): annotatiegereedschappen (currentTool-probe), parametrisch-symboolkiezer, redactie-toepassen (meldingsdialoog zonder redacties), meetgereedschappen en hoeveelheden-paneel. ribbon-clear-all wordt geklikt op een leeg document (bevestigingsflow met annotaties = OS-dialoog, Fase B). Blanco document; niets wordt opgeslagen.",
  "skippedButtons": [
    { "id": "color-picker", "reason": "input[type=color] — klik opent OS-kleurkiezer die de headless run blokkeert; enabled-gedrag wel getoetst" },
    { "id": "tool-clear", "reason": "opent altijd OS-bevestigingsdialoog (dialog.ask) — blokkeert headless run; enabled-gedrag wel getoetst" }
  ],
  "steps": [
    { "action": "tool", "name": "app_new_blank_pdf", "args": { "widthPt": 595, "heightPt": 842, "pages": 1 }, "store": "newdoc" },
    { "action": "wait", "ms": 800 },
    { "action": "uiState", "id": "tab-comment", "store": "uiTabComment" },

    { "action": "clickButton", "id": "tool-highlight" },
    { "action": "probe", "store": "pHighlight" },
    { "action": "clickButton", "id": "tool-textbox" },
    { "action": "probe", "store": "pTextbox" },
    { "action": "clickButton", "id": "tool-callout" },
    { "action": "probe", "store": "pCallout" },
    { "action": "clickButton", "id": "tool-comment" },
    { "action": "probe", "store": "pComment" },
    { "action": "clickButton", "id": "tool-stamp" },
    { "action": "probe", "store": "pStamp" },
    { "action": "clickButton", "id": "tool-signature" },
    { "action": "probe", "store": "pSignature" },
    { "action": "clickButton", "id": "tool-redaction" },
    { "action": "probe", "store": "pRedaction" },
    { "action": "escape", "ms": 200 },

    { "action": "clickButton", "id": "tool-parametric-symbol" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "selector": ".ops-modal", "searchTabs": false, "store": "uiParamPicker" },
    { "action": "clickButton", "selector": ".ops-modal-header button[aria-label=\"Close\"]", "searchTabs": false },
    { "action": "wait", "ms": 300 },
    { "action": "uiState", "selector": ".ops-modal", "searchTabs": false, "store": "uiParamPickerClosed" },

    { "action": "clickButton", "id": "btn-apply-redactions" },
    { "action": "wait", "ms": 500 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgNoRedactions" },
    { "action": "escape", "ms": 400 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgNoRedactionsClosed" },

    { "action": "uiState", "id": "color-picker", "store": "uiColorPicker" },
    { "action": "clickButton", "id": "line-width" },
    { "action": "uiState", "id": "line-width", "store": "uiLineWidth" },
    { "action": "escape", "ms": 200 },

    { "action": "uiState", "id": "tool-clear", "store": "uiToolClear" },
    { "action": "probe", "store": "pPreClearAll" },
    { "action": "clickButton", "id": "ribbon-clear-all" },
    { "action": "wait", "ms": 300 },
    { "action": "probe", "store": "pPostClearAll" },

    { "action": "clickButton", "id": "tool-measure-distance" },
    { "action": "probe", "store": "pMeasDist" },
    { "action": "clickButton", "id": "tool-measure-area" },
    { "action": "probe", "store": "pMeasArea" },
    { "action": "clickButton", "id": "tool-measure-perimeter" },
    { "action": "probe", "store": "pMeasPerim" },
    { "action": "clickButton", "id": "tool-measure-angle" },
    { "action": "probe", "store": "pMeasAngle" },
    { "action": "escape", "ms": 200 },

    { "action": "clickButton", "id": "btn-open-schedule" },
    { "action": "wait", "ms": 500 },
    { "action": "uiState", "id": "btn-open-schedule", "store": "uiSchedule1" },
    { "action": "uiState", "selector": ".schedule-modeless", "searchTabs": false, "store": "uiSchedulePanel" },
    { "action": "clickButton", "id": "btn-open-schedule" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "id": "btn-open-schedule", "store": "uiSchedule2" },

    { "action": "tool", "name": "app_list_tabs", "store": "tabsEnd" },
    { "action": "tool", "name": "app_close_tab", "args": { "index": "={tabsEnd.activeIndex}", "force": true } }
  ],
  "assertions": [
    { "type": "elementFound", "probe": "uiTabComment", "label": "tab-comment content aanwezig" },
    { "type": "stateEquals", "probe": "pHighlight", "field": "currentTool", "value": "highlight", "label": "tool-highlight activeert highlight-tool" },
    { "type": "stateEquals", "probe": "pTextbox", "field": "currentTool", "value": "textbox", "label": "tool-textbox activeert textbox-tool" },
    { "type": "stateEquals", "probe": "pCallout", "field": "currentTool", "value": "callout", "label": "tool-callout activeert callout-tool" },
    { "type": "stateEquals", "probe": "pComment", "field": "currentTool", "value": "comment", "label": "tool-comment activeert notitie-tool" },
    { "type": "stateEquals", "probe": "pStamp", "field": "currentTool", "value": "stamp", "label": "tool-stamp activeert stempel-tool" },
    { "type": "stateEquals", "probe": "pSignature", "field": "currentTool", "value": "signature", "label": "tool-signature activeert handtekening-tool" },
    { "type": "stateEquals", "probe": "pRedaction", "field": "currentTool", "value": "redaction", "label": "tool-redaction activeert redactie-tool" },
    { "type": "elementFound", "probe": "uiParamPicker", "label": "tool-parametric-symbol opent symboolkiezer" },
    { "type": "elementFound", "probe": "uiParamPickerClosed", "found": false, "label": "sluitknop sluit symboolkiezer" },
    { "type": "dialogOpen", "probe": "dlgNoRedactions", "label": "btn-apply-redactions meldt: geen redacties op pagina" },
    { "type": "dialogOpen", "probe": "dlgNoRedactionsClosed", "open": false, "label": "Escape sluit redactie-melding" },
    { "type": "elementEnabled", "probe": "uiColorPicker", "label": "color-picker enabled met document" },
    { "type": "elementEnabled", "probe": "uiLineWidth", "label": "line-width enabled met document" },
    { "type": "elementEnabled", "probe": "uiToolClear", "label": "tool-clear enabled met document" },
    { "type": "annotationCountEquals", "probe": "pPostClearAll", "value": 0, "label": "ribbon-clear-all op leeg document: telling blijft 0, geen crash" },
    { "type": "stateEquals", "probe": "pMeasDist", "field": "currentTool", "value": "measureDistance", "label": "tool-measure-distance activeert afstand-meten" },
    { "type": "stateEquals", "probe": "pMeasArea", "field": "currentTool", "value": "measureArea", "label": "tool-measure-area activeert oppervlakte-meten" },
    { "type": "stateEquals", "probe": "pMeasPerim", "field": "currentTool", "value": "measurePerimeter", "label": "tool-measure-perimeter activeert omtrek-meten" },
    { "type": "stateEquals", "probe": "pMeasAngle", "field": "currentTool", "value": "measureAngle", "label": "tool-measure-angle activeert hoek-meten" },
    { "type": "elementActive", "probe": "uiSchedule1", "label": "btn-open-schedule opent hoeveelheden-paneel (actief)" },
    { "type": "elementFound", "probe": "uiSchedulePanel", "label": "hoeveelheden-paneel zichtbaar" },
    { "type": "elementActive", "probe": "uiSchedule2", "active": false, "label": "btn-open-schedule sluit hoeveelheden-paneel" }
  ]
}
