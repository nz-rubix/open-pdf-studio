{
  "name": "a-home",
  "description": "Fase A rooktest — Start-tab (HomeTab): elke knop geklikt of geprobed met controleerbaar effect. Nieuw blanco document van 3 pagina's; niets wordt opgeslagen.",
  "skippedButtons": [
    { "id": "btn-home-ifc-export", "reason": "opent OS-opslaan-dialoog (IFC-report) — blokkeert headless run; enabled-gedrag wel getoetst" },
    { "id": "btn-home-email", "reason": "start externe e-mailclient — niet scriptbaar; enabled-gedrag wel getoetst" },
    { "id": "btn-home-raster-pdf", "reason": "opent OS-opslaan-dialoog (raster-PDF-export) — blokkeert headless run; enabled-gedrag wel getoetst" }
  ],
  "steps": [
    { "action": "tool", "name": "app_new_blank_pdf", "args": { "widthPt": 595, "heightPt": 842, "pages": 3 }, "store": "newdoc" },
    { "action": "wait", "ms": 800 },
    { "action": "uiState", "id": "tab-home", "store": "uiTabHome" },
    { "action": "probe", "store": "init" },

    { "action": "clickButton", "id": "btn-home-new" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgNew" },
    { "action": "escape", "ms": 400 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgNewClosed" },

    { "action": "uiState", "id": "btn-home-ifc-export", "store": "uiIfc" },
    { "action": "uiState", "id": "btn-home-email", "store": "uiEmail" },
    { "action": "uiState", "id": "btn-home-raster-pdf", "store": "uiRaster" },

    { "action": "clickButton", "id": "tool-hand" },
    { "action": "probe", "store": "pHand" },
    { "action": "clickButton", "id": "tool-select" },
    { "action": "probe", "store": "pSelect" },

    { "action": "clickButton", "id": "screenshot-split-btn", "selector": "#screenshot-split-btn > button.ribbon-btn" },
    { "action": "wait", "ms": 700 },
    { "action": "probe", "store": "pShot" },
    { "action": "clickButton", "id": "screenshot-menu-page" },
    { "action": "wait", "ms": 700 },
    { "action": "clickButton", "id": "screenshot-menu-region" },
    { "action": "wait", "ms": 400 },
    { "action": "uiState", "selector": "#screenshot-overlay-root", "searchTabs": false, "store": "uiRegionOverlay" },
    { "action": "escape", "ms": 400 },
    { "action": "uiState", "selector": "#screenshot-overlay-root", "searchTabs": false, "store": "uiRegionOverlayGone" },
    { "action": "uiState", "id": "screenshot-menu-overlay", "store": "uiShotOverlayBtn" },
    { "action": "probe", "store": "pPreOverlay" },
    { "action": "clickButton", "id": "screenshot-menu-overlay" },
    { "action": "wait", "ms": 600 },
    { "action": "probe", "store": "pPostOverlay" },
    { "action": "tool", "name": "app_undo" },
    { "action": "escape", "ms": 200 },

    { "action": "tool", "name": "app_set_zoom", "args": { "scale": 0.9 } },
    { "action": "wait", "ms": 300 },
    { "action": "probe", "store": "z0" },
    { "action": "clickButton", "id": "zoom-in-ribbon" },
    { "action": "wait", "ms": 400 },
    { "action": "probe", "store": "z1" },
    { "action": "clickButton", "id": "zoom-out-ribbon" },
    { "action": "wait", "ms": 400 },
    { "action": "probe", "store": "z2" },

    { "action": "tool", "name": "app_set_zoom", "args": { "scale": 0.33 } },
    { "action": "wait", "ms": 300 },
    { "action": "probe", "store": "zPreFw" },
    { "action": "clickButton", "id": "fit-width" },
    { "action": "wait", "ms": 500 },
    { "action": "probe", "store": "zFw" },
    { "action": "clickButton", "id": "actual-size-ribbon" },
    { "action": "wait", "ms": 400 },
    { "action": "probe", "store": "zAs" },
    { "action": "tool", "name": "app_set_zoom", "args": { "scale": 2.5 } },
    { "action": "wait", "ms": 300 },
    { "action": "probe", "store": "zPreFp" },
    { "action": "clickButton", "id": "fit-page-ribbon" },
    { "action": "wait", "ms": 500 },
    { "action": "probe", "store": "zFp" },

    { "action": "probe", "store": "pg0" },
    { "action": "uiState", "id": "first-page", "store": "uiFirstAtStart" },
    { "action": "uiState", "id": "prev-page-ribbon", "store": "uiPrevAtStart" },
    { "action": "clickButton", "id": "next-page-ribbon" },
    { "action": "wait", "ms": 400 },
    { "action": "probe", "store": "pg1" },
    { "action": "clickButton", "id": "last-page" },
    { "action": "wait", "ms": 400 },
    { "action": "probe", "store": "pg2" },
    { "action": "uiState", "id": "next-page-ribbon", "store": "uiNextAtEnd" },
    { "action": "uiState", "id": "last-page", "store": "uiLastAtEnd" },
    { "action": "clickButton", "id": "prev-page-ribbon" },
    { "action": "wait", "ms": 400 },
    { "action": "probe", "store": "pg3" },
    { "action": "clickButton", "id": "first-page" },
    { "action": "wait", "ms": 400 },
    { "action": "probe", "store": "pg4" },

    { "action": "clickButton", "id": "ribbon-find" },
    { "action": "wait", "ms": 300 },
    { "action": "uiState", "selector": ".find-bar.visible", "searchTabs": false, "store": "uiFindOpen" },
    { "action": "escape", "ms": 400 },
    { "action": "uiState", "selector": ".find-bar.visible", "searchTabs": false, "store": "uiFindClosed" },

    { "action": "clickButton", "id": "ribbon-preferences" },
    { "action": "wait", "ms": 500 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgPrefs" },
    { "action": "escape", "ms": 400 },
    { "action": "uiState", "selector": ".modal-overlay .modal-dialog", "searchTabs": false, "store": "dlgPrefsClosed" },

    { "action": "tool", "name": "app_list_tabs", "store": "tabsEnd" },
    { "action": "tool", "name": "app_close_tab", "args": { "index": "={tabsEnd.activeIndex}", "force": true } }
  ],
  "assertions": [
    { "type": "elementFound", "probe": "uiTabHome", "label": "tab-home content aanwezig" },
    { "type": "dialogOpen", "probe": "dlgNew", "label": "btn-home-new opent Nieuw-document-dialoog" },
    { "type": "dialogOpen", "probe": "dlgNewClosed", "open": false, "label": "Escape sluit Nieuw-document-dialoog" },
    { "type": "elementEnabled", "probe": "uiIfc", "label": "btn-home-ifc-export enabled met document" },
    { "type": "elementEnabled", "probe": "uiEmail", "label": "btn-home-email enabled met document" },
    { "type": "elementEnabled", "probe": "uiRaster", "label": "btn-home-raster-pdf enabled met document" },
    { "type": "stateEquals", "probe": "pHand", "field": "currentTool", "value": "hand", "label": "tool-hand activeert hand-tool" },
    { "type": "stateEquals", "probe": "pSelect", "field": "currentTool", "value": "select", "label": "tool-select activeert select-tool" },
    { "type": "stateChanged", "preProbe": "init", "postProbe": "pShot", "field": "statusMessage", "label": "screenshot (paginacapture) zet statusmelding" },
    { "type": "elementFound", "probe": "uiRegionOverlay", "label": "screenshot-menu-region toont regio-overlay" },
    { "type": "elementFound", "probe": "uiRegionOverlayGone", "found": false, "label": "Escape sluit regio-overlay" },
    { "type": "elementEnabled", "probe": "uiShotOverlayBtn", "label": "screenshot-menu-overlay enabled na paginacapture" },
    { "type": "annotationCountDelta", "preProbe": "pPreOverlay", "postProbe": "pPostOverlay", "delta": 1, "label": "screenshot-menu-overlay plaatst overlay-annotatie" },
    { "type": "stateChanged", "preProbe": "z0", "postProbe": "z1", "field": "doc.scale", "label": "zoom-in-ribbon verhoogt schaal" },
    { "type": "stateChanged", "preProbe": "z1", "postProbe": "z2", "field": "doc.scale", "label": "zoom-out-ribbon verlaagt schaal" },
    { "type": "stateChanged", "preProbe": "zPreFw", "postProbe": "zFw", "field": "doc.scale", "label": "fit-width past schaal aan" },
    { "type": "stateInRange", "probe": "zAs", "field": "doc.scale", "min": 0.99, "max": 1.01, "label": "actual-size-ribbon zet schaal op 100%" },
    { "type": "stateChanged", "preProbe": "zPreFp", "postProbe": "zFp", "field": "doc.scale", "label": "fit-page-ribbon past schaal aan" },
    { "type": "stateEquals", "probe": "pg0", "field": "doc.currentPage", "value": 1, "label": "startpagina is 1" },
    { "type": "elementEnabled", "probe": "uiFirstAtStart", "enabled": false, "label": "first-page disabled op pagina 1" },
    { "type": "elementEnabled", "probe": "uiPrevAtStart", "enabled": false, "label": "prev-page-ribbon disabled op pagina 1" },
    { "type": "stateEquals", "probe": "pg1", "field": "doc.currentPage", "value": 2, "label": "next-page-ribbon gaat naar pagina 2" },
    { "type": "stateEquals", "probe": "pg2", "field": "doc.currentPage", "value": 3, "label": "last-page gaat naar laatste pagina" },
    { "type": "elementEnabled", "probe": "uiNextAtEnd", "enabled": false, "label": "next-page-ribbon disabled op laatste pagina" },
    { "type": "elementEnabled", "probe": "uiLastAtEnd", "enabled": false, "label": "last-page disabled op laatste pagina" },
    { "type": "stateEquals", "probe": "pg3", "field": "doc.currentPage", "value": 2, "label": "prev-page-ribbon gaat terug naar pagina 2" },
    { "type": "stateEquals", "probe": "pg4", "field": "doc.currentPage", "value": 1, "label": "first-page gaat naar pagina 1" },
    { "type": "elementFound", "probe": "uiFindOpen", "label": "ribbon-find opent zoekbalk" },
    { "type": "elementFound", "probe": "uiFindClosed", "found": false, "label": "Escape sluit zoekbalk" },
    { "type": "dialogOpen", "probe": "dlgPrefs", "label": "ribbon-preferences opent voorkeuren-dialoog" },
    { "type": "dialogOpen", "probe": "dlgPrefsClosed", "open": false, "label": "Escape sluit voorkeuren-dialoog" }
  ]
}
