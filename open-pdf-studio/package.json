{
  "name": "open-pdf-studio",
  "version": "1.70.0",
  "description": "A free, open-source PDF annotation editor built with Tauri",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:debug": "node scripts/run-dev-debug.mjs",
    "tauri:build": "npm run build && tauri build",
    "bump": "node scripts/bump-version.js",
    "typecheck": "tsc --noEmit",
    "test:render": "..\\scripts\\.venv-test\\Scripts\\python.exe ../scripts/render-regression-test.py",
    "test:render:auto": "node ../scripts/run-render-regression.mjs"
  },
  "keywords": [
    "tauri",
    "pdf",
    "editor",
    "annotator",
    "viewer",
    "open-source"
  ],
  "author": "OpenAEC Foundation",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "playwright": "^1.59.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  },
  "dependencies": {
    "@crabnebula/tauri-plugin-drag": "^2.1.0",
    "@tauri-apps/api": "~2.11",
    "@tauri-apps/plugin-dialog": "~2.7",
    "@tauri-apps/plugin-fs": "~2.5",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "mupdf": "^1.27.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "solid-js": "^1.9.11"
  }
}
